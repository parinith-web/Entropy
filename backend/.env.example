# Backend API Configuration
DEBUG=True
ENVIRONMENT=development

# Database URL
# For development, you can leave it empty to use SQLite:
DATABASE_URL=
# For production (PostgreSQL/Neon):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# CORS
# Comma-separated list of origins that can access the API
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Pipeline Trigger Secret
# Generate a secure random string for this. This must match the secret configured in GitHub Actions.
PIPELINE_SECRET=your_secure_pipeline_secret_here

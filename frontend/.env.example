# Frontend Configuration
# Copy this to .env and fill in values for local dev

# Your Backend API URL (Render deployment)
VITE_API_URL=https://your-render-backend.onrender.com

# Google OAuth 2.0 Client ID (required for real Google sign-in)
# Get this from: https://console.cloud.google.com/apis/credentials
# Create an "OAuth 2.0 Client ID" → Web application
# Add Authorized JavaScript origins: https://your-vercel-domain.vercel.app
# Add Authorized redirect URIs: https://your-vercel-domain.vercel.app
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

VITE_ENV=production
